@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- ===== HERO ===== -->
<section id="home" class="hero">
    <div class="hero-content">
        <h1>Discover <span>Incredible India</span><br />North & South</h1>
        <p>From the snow-capped Himalayas to the tropical shores of Kerala — your perfect journey begins here.</p>
        <div class="hero-btns">
            <a href="#destinations" class="btn-primary">Explore Destinations</a>
            <a href="#feedback" class="btn-outline">Book a Tour</a>
        </div>
    </div>
</section>

<!-- ===== STATS BAR ===== -->
<div class="stats-bar">
    <div class="stat"><h3>250+</h3><p>Tours Completed</p></div>
    <div class="stat"><h3>18+</h3><p>Destinations</p></div>
    <div class="stat"><h3>5000+</h3><p>Happy Tourists</p></div>
    <div class="stat"><h3>10+</h3><p>Years Experience</p></div>
</div>

<!-- ===== DESTINATIONS ===== -->
<section id="destinations" class="section bg-light">
    <h2 class="section-title">Our Destinations</h2>
    <div class="divider"></div>
    <p class="section-sub">Handpicked locations across the heart of India</p>

    <h3 class="region-title">🏔️ North India</h3>
    <div class="cards-grid">

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1548013146-72479768bada?w=600&q=80" alt="Taj Mahal" />
            <div class="card-body">
                <h3>Agra – Taj Mahal</h3>
                <p>Visit the iconic symbol of love along with Agra Fort and Fatehpur Sikri.</p>
                <div class="price">₹8,500 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1587474260584-136574528ed5?w=600&q=80" alt="Delhi" />
            <div class="card-body">
                <h3>Delhi – Capital Heritage</h3>
                <p>Explore Red Fort, Qutub Minar, India Gate and vibrant lanes of Old Delhi.</p>
                <div class="price">₹6,500 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1512343879784-a960bf40e7f2?w=600&q=80" alt="Jaipur" />
            <div class="card-body">
                <h3>Jaipur – Pink City</h3>
                <p>Discover the majestic Amber Fort, Hawa Mahal, and colorful Rajasthani bazaars.</p>
                <div class="price">₹9,200 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1626621341517-bbf3d9990a23?w=600&q=80" alt="Shimla" />
            <div class="card-body">
                <h3>Shimla – Queen of Hills</h3>
                <p>Enjoy scenic mountain views, colonial architecture and cool Himalayan breezes.</p>
                <div class="price">₹12,000 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1598091383021-15ddea10925d?w=600&q=80" alt="Varanasi" />
            <div class="card-body">
                <h3>Varanasi – Holy Ganga</h3>
                <p>Experience the spiritual Ganga Aarti, ancient temples and timeless ghats.</p>
                <div class="price">₹7,800 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1609766418204-94aae0ecfdfc?w=600&q=80" alt="Manali" />
            <div class="card-body">
                <h3>Manali – Adventure Hub</h3>
                <p>Trekking, snow sports, Rohtang Pass and Solang Valley await you.</p>
                <div class="price">₹14,500 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

    </div>

    <h3 class="region-title">🌴 South India</h3>
    <div class="cards-grid">

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?w=600&q=80" alt="Kerala" />
            <div class="card-body">
                <h3>Kerala – God's Own Country</h3>
                <p>Cruise the serene backwaters of Alleppey and lush tea gardens of Munnar.</p>
                <div class="price">₹13,000 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1582510003544-4d00b7f74220?w=600&q=80" alt="Mysore" />
            <div class="card-body">
                <h3>Mysore – City of Palaces</h3>
                <p>Marvel at the illuminated Mysore Palace, Chamundi Hills and sandalwood markets.</p>
                <div class="price">₹9,500 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1596422846543-75c6fc197f07?w=600&q=80" alt="Ooty" />
            <div class="card-body">
                <h3>Ooty – Queen of Nilgiris</h3>
                <p>Ride the toy train, explore tea estates, Botanical Garden and Ooty Lake.</p>
                <div class="price">₹10,200 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1588416936097-41850ab3d86d?w=600&q=80" alt="Chennai" />
            <div class="card-body">
                <h3>Chennai – Cultural Capital</h3>
                <p>Visit Marina Beach, Kapaleeshwarar Temple and experience South Indian culture.</p>
                <div class="price">₹7,200 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=600&q=80" alt="Hampi" />
            <div class="card-body">
                <h3>Hampi – Ancient Ruins</h3>
                <p>Explore the UNESCO World Heritage Vijayanagara ruins amid boulder landscapes.</p>
                <div class="price">₹8,900 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

        <div class="dest-card">
            <img src="https://images.unsplash.com/photo-1590050752117-238cb0fb12b1?w=600&q=80" alt="Pondicherry" />
            <div class="card-body">
                <h3>Pondicherry – French Riviera</h3>
                <p>Stroll colonial streets, beaches, Auroville and serene ashram retreats.</p>
                <div class="price">₹8,000 <span>/ person</span></div>
                <a href="#feedback" class="card-btn">Book Now</a>
            </div>
        </div>

    </div>
</section>

<!-- ===== TOUR LIST ===== -->
<section id="tourlist" class="section">
    <h2 class="section-title">Tour List</h2>
    <div class="divider"></div>
    <p class="section-sub">All available tour packages at a glance</p>

    <table class="tour-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Tour Name</th>
                <th>Region</th>
                <th>Duration</th>
                <th>Price (per person)</th>
                <th>Best Season</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <tr><td>1</td><td>Taj Mahal & Agra Fort</td><td><span class="badge badge-north">North</span></td><td>2 Days</td><td>₹8,500</td><td>Oct – Mar</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>2</td><td>Delhi Heritage Walk</td><td><span class="badge badge-north">North</span></td><td>3 Days</td><td>₹6,500</td><td>Nov – Feb</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>3</td><td>Jaipur Royal Tour</td><td><span class="badge badge-north">North</span></td><td>4 Days</td><td>₹9,200</td><td>Oct – Mar</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>4</td><td>Shimla Hill Station</td><td><span class="badge badge-north">North</span></td><td>5 Days</td><td>₹12,000</td><td>Mar – Jun</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>5</td><td>Varanasi Spiritual Tour</td><td><span class="badge badge-north">North</span></td><td>3 Days</td><td>₹7,800</td><td>Oct – Mar</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>6</td><td>Manali Adventure Trip</td><td><span class="badge badge-north">North</span></td><td>6 Days</td><td>₹14,500</td><td>May – Sep</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>7</td><td>Kerala Backwaters</td><td><span class="badge badge-south">South</span></td><td>5 Days</td><td>₹13,000</td><td>Sep – Mar</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>8</td><td>Mysore Palace & Coorg</td><td><span class="badge badge-south">South</span></td><td>4 Days</td><td>₹9,500</td><td>Oct – Feb</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>9</td><td>Ooty Nilgiri Express</td><td><span class="badge badge-south">South</span></td><td>3 Days</td><td>₹10,200</td><td>Apr – Jun</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>10</td><td>Chennai Temple Trail</td><td><span class="badge badge-south">South</span></td><td>3 Days</td><td>₹7,200</td><td>Nov – Feb</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>11</td><td>Hampi Historical Tour</td><td><span class="badge badge-south">South</span></td><td>2 Days</td><td>₹8,900</td><td>Oct – Mar</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
            <tr><td>12</td><td>Pondicherry French Town</td><td><span class="badge badge-south">South</span></td><td>3 Days</td><td>₹8,000</td><td>Oct – Mar</td><td><a href="#feedback" class="card-btn">Book</a></td></tr>
        </tbody>
    </table>
</section>

<!-- ===== FEEDBACK / BOOKING FORM ===== -->
<section id="feedback" class="section bg-light">
    <h2 class="section-title">Book a Tour / Feedback</h2>
    <div class="divider"></div>
    <p class="section-sub">Fill in your details and we will contact you within 24 hours</p>

    <div class="form-grid">
        <form method="post">
            @Html.AntiForgeryToken()

            <div class="form-row">
                <div class="form-group">
                    <label>First Name</label>
                    <input type="text" name="FirstName" placeholder="Your first name" required />
                </div>
                <div class="form-group">
                    <label>Last Name</label>
                    <input type="text" name="LastName" placeholder="Your last name" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="Email" placeholder="email@example.com" required />
                </div>
                <div class="form-group">
                    <label>Phone Number</label>
                    <input type="tel" name="Phone" placeholder="+91 XXXXXXXXXX" required />
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Select Region</label>
                    <select name="Region" required>
                        <option value="">-- Choose Region --</option>
                        <option>North India</option>
                        <option>South India</option>
                        <option>Both North & South India</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Select Tour Package</label>
                    <select name="Package" required>
                        <option value="">-- Choose Package --</option>
                        <optgroup label="North India">
                            <option>Taj Mahal & Agra Fort</option>
                            <option>Delhi Heritage Walk</option>
                            <option>Jaipur Royal Tour</option>
                            <option>Shimla Hill Station</option>
                            <option>Varanasi Spiritual Tour</option>
                            <option>Manali Adventure Trip</option>
                        </optgroup>
                        <optgroup label="South India">
                            <option>Kerala Backwaters</option>
                            <option>Mysore Palace & Coorg</option>
                            <option>Ooty Nilgiri Express</option>
                            <option>Chennai Temple Trail</option>
                            <option>Hampi Historical Tour</option>
                            <option>Pondicherry French Town</option>
                        </optgroup>
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label>Travel Date</label>
                    <input type="date" name="TravelDate" required />
                </div>
                <div class="form-group">
                    <label>Number of Persons</label>
                    <input type="number" name="Persons" placeholder="e.g. 2" min="1" max="50" required />
                </div>
            </div>

            <div class="form-group">
                <label>Message / Special Requests</label>
                <textarea name="Message" placeholder="Write your message or special requirements..."></textarea>
            </div>

            @if (ViewData["SuccessMessage"] != null)
            {
                <div class="success-msg" style="display:block;">✅ @ViewData["SuccessMessage"]</div>
            }

            <button type="submit" class="form-submit">Submit Booking / Feedback</button>
        </form>
    </div>
</section>

<!-- ===== RULES & REGULATIONS ===== -->
<section id="rules" class="section">
    <h2 class="section-title">Rules & Regulations</h2>
    <div class="divider"></div>
    <p class="section-sub">Please read our guidelines before booking</p>

    <div class="rules-grid">
        <div class="rule-card">
            <h4>📋 Booking Policy</h4>
            <p>All bookings must be confirmed with a 30% advance payment. Full payment is required 7 days before departure.</p>
        </div>
        <div class="rule-card">
            <h4>❌ Cancellation Policy</h4>
            <p>Cancellations 15+ days before departure receive 80% refund. Cancellations within 7 days are non-refundable.</p>
        </div>
        <div class="rule-card">
            <h4>🪪 ID & Documents</h4>
            <p>All tourists must carry a valid government-issued photo ID. For international tourists, a valid passport is mandatory.</p>
        </div>
        <div class="rule-card">
            <h4>🚌 Travel Rules</h4>
            <p>Tourists must report at the pickup point 30 minutes before departure. Late arrivals may forfeit their seat.</p>
        </div>
        <div class="rule-card">
            <h4>🏨 Accommodation</h4>
            <p>Hotels are twin-sharing by default. Single occupancy rooms can be arranged at an additional cost.</p>
        </div>
        <div class="rule-card">
            <h4>🌿 Conduct & Safety</h4>
            <p>Tourists must respect local customs and monuments. Any damage to property will be charged directly.</p>
        </div>
    </div>
</section>

<!-- ===== CONTACT US ===== -->
<section id="contact" class="section bg-light">
    <h2 class="section-title">Contact Us</h2>
    <div class="divider"></div>
    <p class="section-sub">Get in touch with our travel experts</p>

    <div class="contact-grid">
        <div class="contact-info">
            <h3>Grace Tours & Travels</h3>
            <p><strong>📍 Address:</strong><br />1, Bhanu, Kolkata - 700072, West Bengal, India</p>
            <p><strong>📞 Phone:</strong><br />+91 1234567890</p>
            <p><strong>📧 Email:</strong><br />info@gracetourstravels.com</p>
            <p><strong>🕐 Office Hours:</strong><br />Mon – Sat: 9:00 AM – 7:00 PM</p>
        </div>
        <div class="contact-form">
            <div class="form-group">
                <label>Your Name</label>
                <input type="text" placeholder="Full Name" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" placeholder="Your Email" />
            </div>
            <div class="form-group">
                <label>Message</label>
                <textarea placeholder="How can we help you?"></textarea>
            </div>
            <button class="form-submit" style="background:var(--purple-dark)">Send Message</button>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.querySelectorAll('a[href^="#"]').forEach(a => {
            a.addEventListener('click', e => {
                e.preventDefault();
                const el = document.querySelector(a.getAttribute('href'));
                if (el) el.scrollIntoView({ behavior: 'smooth' });
            });
        });
    </script>
}
